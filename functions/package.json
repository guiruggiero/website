{
  "name": "functions",
  "description": "Cloud Functions for Firebase",
  "type": "module",
  "engines": {
    "node": "22"
  },
  "private": true,
  "main": "index.js",
  "dependencies": {
    "@google/genai": "^1.48.0",
    "@langfuse/client": "^5.0.2",
    "@sentry/node": "^10.47.0",
    "firebase-functions": "^7.1.1",
    "sanitize-html": "^2.17.0"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.3.5",
    "@eslint/js": "^10.0.1",
    "eslint": "^10.2.0",
    "eslint-config-google": "^0.14.0",
    "firebase-tools": "^15.13.0",
    "globals": "^17.4.0"
  },
  "scripts": {
    "lint": "eslint .",
    "lint-fix": "eslint . --fix",
    "deploy": "npx firebase deploy --only functions:guipt,functions:guiwise",
    "deploy-guipt": "npx firebase deploy --only functions:guipt",
    "deploy-guiwise": "npx firebase deploy --only functions:guiwise",
    "prompt-pull": "node --env-file=.env scripts/prompt.js pull",
    "prompt-push": "node --env-file=.env scripts/prompt.js push"
  }
