{
  "name": "functions",
  "description": "Cloud Functions for Firebase",
  "type": "module",
  "engines": {
    "node": "22"
  },
  "private": true,
  "main": "index.js",
  "dependencies": {
    "@google/genai": "^2.9.0",
    "@langfuse/client": "^5.5.3",
    "@sentry/node": "^10.59.0",
    "firebase-functions": "^7.2.5",
    "nodemailer": "^8.0.7",
    "sanitize-html": "^2.17.5"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.3.5",
    "@eslint/js": "^10.0.1",
    "eslint": "^10.5.0",
    "eslint-config-google": "^0.14.0",
    "firebase-tools": "^15.22.3",
    "globals": "^17.6.0"
  },
  "scripts": {
    "lint": "eslint .",
    "lint-fix": "eslint . --fix",
